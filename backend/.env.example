# ================================
# AI Email Manager - Backend .env
# ================================

# App Core Configuration
PORT=3001
NODE_ENV=development

# ---------------------------------------------------------
# AWS SECRETS MANAGER (MANDATORY FOR SENSITIVE DATA)
# ---------------------------------------------------------
# Toàn bộ thông tin nhạy cảm (Database, JWT, AES, OAuth, n8n webhook)
# đã được chuyển sang AWS Secrets Manager.
# 
# Hãy copy nội dung file `aws-secret.template.json`, điền thông tin của bạn
# và tạo 1 Secret mới trên AWS Secrets Manager với định dạng Key/Value.
# Sau đó điền thông tin AWS vào đây:
# ---------------------------------------------------------

AWS_REGION="ap-southeast-1"
AWS_APP_SECRET_NAME="prod/ai-email-manager"

# Lưu ý: Nếu bạn chạy ở localhost, bạn cần khai báo thêm AWS Access Key
# để có quyền gọi AWS Secrets Manager:
# AWS_ACCESS_KEY_ID="your-access-key"
# AWS_SECRET_ACCESS_KEY="your-secret-key"
