    "prisma:push": "ts-node scripts/run-prisma.ts db push",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.454.0",
