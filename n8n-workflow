        "jsCode": "// Lấy lịch sử chat từ biến toàn cục\nconst sessionId = $json.sessionId;\nconst globalKey = `chat_history_${sessionId}`;\n\n// Lấy history từ global (nếu có)\nlet history = $getWorkflowStaticData('global')[globalKey] || [];\n\n// Thêm tin nhắn hiện tại\nhistory.push({\n  role: 'user',\n  content: $json.message\n});\n\n// Chỉ giữ 10 tin nhắn gần nhất\nif (history.length > 10) {\n  history = history.slice(-10);\n}\n\n// Lưu lại\n$getWorkflowStaticData('global')[globalKey] = history;\n\n// Tạo context cho AI\nconst context = history.map(msg => \n  `${msg.role === 'user' ? 'Người dùng' : 'Trợ lý'}: ${msg.content}`\n).join('\\n');\n\nreturn [{\n  json: {\n    ...$json,\n    chat_context: context,\n    message: $json.message\n  }\n}];"
