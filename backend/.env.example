# ================================
# AI Email Manager - Backend .env
# ================================

# App
PORT=3001
NODE_ENV=development

# Database (PostgreSQL - same instance as n8n)
DATABASE_URL="postgresql://postgres:password@localhost:5432/ai_email_manager"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_SECRET="your-refresh-token-secret-change-this"
JWT_REFRESH_EXPIRY="7d"

# AES Encryption (for OAuth tokens at rest)
AES_SECRET_KEY="exactly-32-characters-long-key!!"

# Frontend URL (for CORS + OAuth redirect)
FRONTEND_URL="http://localhost:3000"

# Gmail OAuth2 (from Google Cloud Console)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:3001/connect/gmail/callback"

# Discord OAuth2 (from Discord Developer Portal)
DISCORD_CLIENT_ID="your-discord-client-id"
DISCORD_CLIENT_SECRET="your-discord-client-secret"
DISCORD_REDIRECT_URI="http://localhost:3001/connect/discord/callback"

# n8n Webhook URLs
N8N_BASE_URL="http://localhost:5678"
N8N_WEBHOOK_CHAT="http://localhost:5678/webhook/discord-agent"
N8N_WEBHOOK_DRAFT="http://localhost:5678/webhook/email-draft"
N8N_WEBHOOK_SEND="http://localhost:5678/webhook/email-send"
