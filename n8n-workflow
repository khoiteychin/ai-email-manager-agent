      "parameters": {
        "jsCode": "const body = $input.item.json.body;\n\nconst userId = body.userId || '';\nconst username = body.username || 'unknown';\nconst messageText = (body.content || '').trim();\nconst channelId = body.channelId || '';\n\nif (!messageText) return [];\n\nconst lowerText = messageText.toLowerCase();\n\n// default\nlet intent = 'chat';\nlet commandArgs = messageText;\n\n// ========================\n// DRAFT\n// ========================\nif (/^(\\/draft\\b|tạo draft|soạn draft|draft email)/i.test(lowerText)) {\n  intent = 'draft';\n  commandArgs = messageText.replace(/^(\\/draft\\s*|tạo draft\\s*|soạn draft\\s*|draft email\\s*)/i, '').trim();\n}\n\n// ========================\n// SEND\n// ========================\nelse if (/^(\\/send\\b|gửi email|send email)/i.test(lowerText)) {\n  intent = 'send';\n  commandArgs = messageText.replace(/^(\\/send\\s*|gửi email\\s*|send email\\s*)/i, '').trim();\n}\n\n\n// ========================\n// EMAIL / RAG QUERY\n// ========================\nelse if (/(email|hộp thư|tin nhắn|đọc|tóm tắt|kiểm tra|tìm)/i.test(lowerText)) {\n  intent = 'chat';\n}\n\n// ========================\n// DEFAULT\n// ========================\nelse {\n  intent = 'chat';\n}\n\nreturn [{\n  json: {\n    userId,\n    username,\n    message: messageText,\n    intent,\n    commandArgs,\n    messageType: 'text',\n    timestamp: Date.now(),\n    channelId\n  }\n}];"
      },
