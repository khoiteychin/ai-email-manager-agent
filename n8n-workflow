      "parameters": {
        "jsCode": "// ============================================================\n// Xử lý kết quả AI — tách biệt AI output vs dữ liệu email gốc\n// ============================================================\nconst items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  // -----------------------------------------------------------\n  // 1. LẤY DỮ LIỆU EMAIL GỐC từ node \"Get Mail Data\"\n  // -----------------------------------------------------------\n  let emailData = {};\n  try {\n    emailData = $('Get Mail Data').item.json;\n  } catch (e) {\n    // Nếu không tìm được, fallback về item hiện tại\n    emailData = item.json;\n  }\n\n  // -----------------------------------------------------------\n  // 2. EXTRACT AI OUTPUT (từ node \"Message a model\")\n  // Hỗ trợ nhiều format output của OpenAI / Langchain node\n  // -----------------------------------------------------------\n  const aiRaw = item.json;\n  let rawString =\n    // n8n OpenAI node (langchain) v2.x\n    aiRaw?.content?.[0]?.text ||\n    aiRaw?.content?.[0]?.content ||\n    (Array.isArray(aiRaw?.content) ? aiRaw.content.map(c => c.text || c.content || '').join('') : '') ||\n    // n8n OpenAI node legacy\n    aiRaw?.choices?.[0]?.message?.content ||\n    // Generic fallbacks\n    aiRaw?.output?.[0]?.content?.[0]?.text ||\n    aiRaw?.output?.[0]?.text ||\n    aiRaw?.output_text ||\n    aiRaw?.message?.content ||\n    aiRaw?.text ||\n    (typeof aiRaw?.content === 'string' ? aiRaw.content : '') ||\n    '';\n\n  // -----------------------------------------------------------\n  // 3. PARSE JSON từ AI output\n  // -----------------------------------------------------------\n  let aiResult = {};\n  if (typeof rawString === 'string' && rawString.includes('{')) {\n    try {\n      const clean = rawString\n        .replace(/```json/gi, '')\n        .replace(/```/g, '')\n        .trim();\n      // Tìm block JSON đầu tiên nếu có text thừa xung quanh\n      const jsonMatch = clean.match(/\\{[\\s\\S]*\\}/);\n      if (jsonMatch) {\n        aiResult = JSON.parse(jsonMatch[0]);\n      }\n    } catch (e) {\n      // AI không trả JSON hợp lệ → giữ nguyên rỗng, fallback bên dưới\n    }\n  }\n\n  // -----------------------------------------------------------\n  // 4. NỘI DUNG EMAIL (body) — lấy từ email gốc\n  // -----------------------------------------------------------\n  const bodyText = (\n    emailData.text ||\n    emailData.textPlain ||\n    emailData.snippet ||\n    ''\n  ).trim();\n\n  const textLower = bodyText.toLowerCase();\n\n  // -----------------------------------------------------------\n  // 5. SUBJECT — từ email gốc\n  // -----------------------------------------------------------\n  const subject =\n    emailData.subject ||\n    emailData.headers?.subject ||\n    '(không có tiêu đề)';\n\n  // -----------------------------------------------------------\n  // 6. FROM — hỗ trợ cả Gmail full format và simple format\n  // -----------------------------------------------------------\n  let from_name = '';\n  let from_address = '';\n\n  if (emailData.from?.value?.[0]?.address) {\n    from_name    = emailData.from.value[0].name    || '';\n    from_address = emailData.from.value[0].address || '';\n  } else if (typeof emailData.from === 'string') {\n    const match = emailData.from.match(/^(.*?)\\s*<(.+?)>$/);\n    if (match) {\n      from_name    = match[1].trim();\n      from_address = match[2].trim();\n    } else {\n      from_address = emailData.from.trim();\n    }\n  } else if (emailData.headers?.from) {\n    const match = emailData.headers.from.match(/^(.*?)\\s*<(.+?)>$/);\n    if (match) {\n      from_name    = match[1].trim();\n      from_address = match[2].trim();\n    } else {\n      from_address = emailData.headers.from.trim();\n    }\n  }\n\n  // -----------------------------------------------------------\n  // 7. TO ADDRESS\n  // -----------------------------------------------------------\n  let to_address = '';\n  if (emailData.to?.value?.[0]?.address) {\n    to_address = emailData.to.value[0].address;\n  } else if (typeof emailData.to === 'string') {\n    const m = emailData.to.match(/<(.+?)>/);\n    to_address = m ? m[1] : emailData.to.trim();\n  }\n\n  // -----------------------------------------------------------\n  // 8. MESSAGE ID & DATE\n  // -----------------------------------------------------------\n  const message_id =\n    emailData.id ||\n    emailData.messageId ||\n    emailData.message_id ||\n    '';\n\n  const emailDate =\n    emailData.date ||\n    emailData.internalDate ||\n    new Date().toISOString();\n\n  // -----------------------------------------------------------\n  // 9. AI FIELDS — ưu tiên kết quả AI, fallback về rule-based\n  // -----------------------------------------------------------\n\n  // CATEGORY\n  let category = aiResult.category || '';\n  if (!category || category === 'Khác') {\n    if (/otp|mã xác nhận|verification code|security code/.test(textLower))     category = 'OTP/Bảo mật';\n    else if (/invoice|receipt|bill|payment|hóa đơn/.test(textLower))           category = 'Hóa đơn';\n    else if (/sale|discount|promotion|offer|unsubscribe|khuyến mãi/.test(textLower)) category = 'Quảng cáo';\n    else if (/facebook|instagram|linkedin|twitter/.test(textLower))             category = 'Mạng xã hội';\n    else if (/meeting|deadline|project|client|họp|dự án/.test(textLower))      category = 'Công việc';\n    else if (/đi chơi|cafe|ăn|hẹn|party/.test(textLower))                      category = 'Cá nhân';\n    else                                                                         category = aiResult.category || 'Khác';\n  }\n\n  // PRIORITY\n  let priority = aiResult.priority || '';\n  if (!priority) {\n    if (/otp|gấp|asap|hôm nay|urgent/.test(textLower)) priority = 'high';\n    else if (category === 'Công việc')                  priority = 'medium';\n    else                                                priority = 'low';\n  }\n\n  // SUMMARY\n  let summary = (aiResult.summary || '').trim();\n  if (!summary) summary = bodyText.slice(0, 200) || 'Email ngắn, không đủ thông tin để tóm tắt';\n\n  // KEY POINTS\n  let key_points = Array.isArray(aiResult.key_points) ? aiResult.key_points : [];\n  if (key_points.length === 0 && summary) key_points = [summary];\n\n  // SUGGESTED ACTION\n  const suggested_action = (aiResult.suggested_action || '').trim();\n\n  // REPLY NEEDED\n  const reply_needed =\n    typeof aiResult.reply_needed === 'boolean'\n      ? aiResult.reply_needed\n      : category === 'Công việc';\n\n  // SENTIMENT\n  const sentiment = aiResult.sentiment || 'neutral';\n\n  // -----------------------------------------------------------\n  // 10. discord MESSAGE\n  // -----------------------------------------------------------\n  const priorityLabel =\n    priority === 'high'   ? '🔴 Cao' :\n    priority === 'medium' ? '🟡 Trung bình' :\n                            '🟢 Thấp';\n\n  const discord_message =\n`📧 *Email mới*\n\n📂 *Loại:* ${category}\n⚡ *Ưu tiên:* ${priorityLabel}\n👤 *Từ:* ${from_name}${from_address ? ' (' + from_address + ')' : ''}\n📌 *Tiêu đề:* ${subject}\n📅 *Ngày:* ${emailDate}\n\n📝 *Tóm tắt:*\n${summary}\n\n${key_points.length > 0 ? '🔑 *Điểm chính:*\\n' + key_points.map(p => '• ' + p).join('\\n') + '\\n\\n' : ''}${suggested_action ? '💡 *Đề xuất:* ' + suggested_action + '\\n\\n' : ''}${reply_needed ? '⚠️ _Email này cần trả lời_' : ''}\n\n_Hỏi về email này: gõ câu hỏi bất kỳ_`;\n\n  // -----------------------------------------------------------\n  // 11. OUTPUT\n  // -----------------------------------------------------------\n  results.push({\n    json: {\n      category,\n      priority,\n      summary,\n      key_points,\n      suggested_action,\n      reply_needed,\n      sentiment,\n      subject,\n      from_name,\n      from_address,\n      to_address,\n      date: emailDate,\n      message_id,\n      body_text: bodyText,\n      id: message_id,\n      discord_message\n    }\n  });\n}\n\nreturn results;"
      },
